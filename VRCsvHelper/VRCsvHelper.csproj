<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>VRCsvHelper</PackageId>
    <Version>1.0.0</Version>
    <Authors>vytenis999</Authors>
    <Description>A simple, reusable CSV import/export library for .NET.</Description>
    <PackageTags>csv;import;export;parser</PackageTags>
    <RepositoryUrl>https://github.com/vytenis999/VRCsvHelper</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

</Project>